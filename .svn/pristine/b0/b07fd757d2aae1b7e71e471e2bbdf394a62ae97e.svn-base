import json
from langchain_cohere import ChatCohere
from langchain_google_genai import ChatGoogleGenerativeAI
import os





def process_data(all_dict):
  for k,v in all_dict.items():
    if type(v) == list:
      for indx,val in enumerate(v):
        if v == '':
          v.pop(indx)
      all_dict[k] = [i for i in v if i !='']
      all_dict[k]= list(set(all_dict[k]))
  return all_dict


def generate_filter(all_dict,user_query):
  '''
  Parameters:
  all_dict -> Dictionary of unique values list for each key passed in prompt for llm to choose one value from
  user_query -> The user query for which the llm create the payload filters

  Returns the metadata/payload filter generated by the llm.

  What the function does is that it gets the user query and gives the LLM prompt using all_dict and and some examples(Few Shot Prompting)
  and asks the LLM model to generate metadata filters and returns them for further use.
  '''

  google_api_key = os.getenv("GOOGLE_API_KEY")
  llm = ChatGoogleGenerativeAI(
          model="gemini-2.0-flash-lite",
          temperature=0,
          google_api_key=google_api_key,
  )
  all_dict = process_data(all_dict)
  example_prompt = ''
  for k,v in all_dict.items():
    example_prompt+=(k+': '+str(v) + '\n\n')


  prompt = f'''You are an intelligent assistant that generates Qdrant filter JSON objects for narrowing down vector search results based on user queries.

  **Task:**
  Given:
  - A user query describing desired candidate attributes
  - A metadata schema listing valid fields and possible values
  - Preferably use skills_total_keywords keys for creating filters when querying for developers

  You must:
  0. Not use job title keys
  1. Analyze the user query to identify which metadata fields are relevant.
  2. For each relevant field:
  - If the field contains multiple values (arrays), use the `match` operator with `any`.
  - If the field contains a single value (string or number), use the `match` or `range` operator as appropriate.
  3. Create a Qdrant-compatible filter object that uses the `must` clause with appropriate `match` or `range` operators.
  4. If no metadata fields match the query, respond with exactly:
  "No filters applicable."
  5. Do not include any additional explanations or formatting in your output.
  6. Choose multiple values with any from the metadata schema if appropriate and don't use must with it then use should.
  7. For Queries requiring logical OR use should.
  8. Apply or logically for all queries untill or unless explicitly asked for and .

  **Output Format:**
  If applicable, respond with a JSON object:
  ```
  {{
  "should": [
    {{"key": "location", "match": {{"value": "Bengaluru, India"}}}},
    {{"key": "location", "match": {{"value": "Bangalore"}}}},
    {{"key": "location", "match": {{"value": "Bangalore, India (Remote)"}}}},
    {{"key": "location", "match": {{"value": "Bengaluru, Karnataka, India"}}}},
    {{"key": "location", "match": {{"value": "Bangalore, Karnataka"}}}}
  ]
}}
  {{
"must": [
  {{
    "key": "current_job_title",
    "match": {{
      "value": "Senior Developer"
    }}
  }},
  {{
    "key": "years_of_experience",
    "range": {{
      "gte": 5,
      "lte": 10
    }}
  }},
  {{
    "key": "skills_languages",
    "match": {{
      "any": ["Python", "JavaScript"]
    }}
  }},
  {{
    "key": "location",
    "match": {{
      "value": "Mumbai"
    }}
  }}
],
"must_not": [
  {{
    "key": "current_company",
    "match": {{
      "value": "Protegrity"
    }}
  }}
]
}}
  If no filters apply, respond with:
  "No filters applicable."
  Metadata Schema:
  Provide only the following fields and values for filtering (you must pick from these values):

  {{
  {example_prompt}
  }}

  User Query:
  {user_query}
  '''
  print('PROMPT:')

  result = llm.invoke(prompt)
  str_data = result.content.strip('```')
  try:
      metadata_filter = json.loads(str_data.lstrip('json'))
      print(metadata_filter)
  except:
      metadata_filter = str_data
      pass

  return metadata_filter


