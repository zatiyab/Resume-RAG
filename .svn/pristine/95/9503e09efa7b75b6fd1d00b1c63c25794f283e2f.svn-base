load_dotenv()


llm = ChatCohere(model="command-r-plus",timeout_seconds=60,cohere_api_key=os.getenv('COHERE_API_KEY'))

embedding = SentenceTransformer("BAAI/bge-large-en-v1.5")
#Vector database client
client = QdrantClient(
    url="http://localhost:6333",
    timeout=60.0
)

client.delete_collection(collection_name="history")
remove_same_files('resumes')

def clean_data(all_dict):
    '''
    Removes duplicated from the unique json file
    takes and returns all_dict which is later saved to unique.json
    '''
    for k,v in all_dict.items():
        if type(v) == list:
            all_dict[k] = [i for i in list(set(v)) if i !=""]
    return all_dict




def initialise_collections(db_name):
    
    if not client.collection_exists(db_name):
        client.create_collection(
                collection_name=db_name,
                vectors_config=VectorParams(
                    size=1024,
                    distance=Distance.COSINE,
                    hnsw_config= HnswConfigDiff(
                                    m=16,
                                    ef_construct=128,
                                    full_scan_threshold=10000
                                ),
                    on_disk=False
                )
        )

        if db_name == 'resumes':
            add_vectors()
            with open("unique.json", "w", encoding="utf-8") as f:
                all_dict = create_unique(client,all_dict)
                all_dict = clean_data(all_dict)
                json.dump(all_dict, f, ensure_ascii=False, indent=4)
    
    with open('unique.json','r') as f:
        all_dict = json.load(f)
        all_dict = clean_data(all_dict)
    for k,v in all_dict.items():
        
        # Change datatypes of paload index for filters
        # total_years_of_experience metadata/payload will be a float
        # graduation_year will be int
        # rest will be keywords
        
        if k == 'total_years_of_experience':
            client.create_payload_index(
                collection_name="resumes",
                field_name=k,
                field_schema=rest.PayloadSchemaType.FLOAT
            )
        elif k== 'graduation_year':
            client.create_payload_index(
                collection_name="resumes",
                field_name=k,
                field_schema=rest.PayloadSchemaType.INTEGER
            )
        else:
            client.create_payload_index(
                collection_name="resumes",
                field_name=k,
                field_schema=rest.PayloadSchemaType.KEYWORD
            )

print('Imported All Dict')
with open('unique.json','r') as f:
    all_dict = json.load(f)

print(all_dict)
initialise_collections('resumes')
initialise_collections('history')

#Initialise history vector id
hist_id = 1
def add_history(history:str):
    '''
    Get history for the LLM chatbot and converts it into a vector
    and also add it to the vector history db and prints the result of the upsert operation
    '''
    import datetime
    global hist_id
    vector = embedding.encode(history)
    point = PointStruct(id=hist_id, vector=vector,payload={"created_at": datetime.datetime.utcnow().isoformat(),
                       'history':history})
    operation_info = client.upsert(
            collection_name="history",
            wait=True,
            points=[point]
        )
    hist_id+=1
    print(operation_info)


def get_relevant_docs(user_query,collection,filter_data = True,k=5):
    '''
    Input parameters:
    user_query -> The main query that the user gives
    collection -> The name of the collecetion for which the function has to get relevant docs
    filter_data -> Whether to filter data or not
    k -> Retrieving parameter how many docs to return.

    Gets relevant documents to the user query from the collection given in the input and if the
    filter data is True filters the collection accordingly and returns k documents

    Returns all_data -> All the k documents joined together in one string
    
    '''
        
    if filter_data:
        with open('unique.json','r') as f:
            all_dict = json.load(f)
            all_dict = clean_data(all_dict)
        filter = generate_filter(all_dict=all_dict,user_query=user_query)
    else:
        filter = {}

    search_result = client.query_points(
        collection_name=collection,
        query=embedding.encode(('Represent this sentence for retrieval: '+user_query).lower()),
        limit=k,
        query_filter= filter if type(filter)!=str else {}
    )
    results = search_result.model_dump()
    all_data = ''
    selected_files = []

    for result in results['points']:
        res_id = result['id']
        score = result['score']
        print('ID: ',res_id) # Prints the point id of the vector doc retrieved
        print('Similarity Score: ',score) # Prints the similarity score of the retrieved doc to the user query
        print(result['payload']) # Prints the metadata for each retrieved doc
        if filter_data:
            source = result['payload']['source']
            print('Source: ',source)
            selected_files.append(str(source))
            data = result['payload']['page_content']  
        else:     
            data = result['payload']['history']
        all_data+=str(data)
        all_data+='\n\n'

    if filter_data:
        # Save selected files to the streamlit session if filter_data is True only true for resumes collection 
        st.session_state.retrieval_result = {"files": selected_files}
  
    return all_data

def main(k,user_query):
    '''
    Renders all the main streamlit components and runs all the main logic.
    '''

    # print(st.session_state)
    # if 'history' not in st.session_state:
    #     # Deletes history per session
    #     print('Deleting History')
    #     client.delete_collection(collection_name="history")
    # st.session_state['history'] = True

    # st_query = st.text_input("Enter your Query",key = 'key1')
    # k = st.slider('How many results you want :',1,20,5)

    # user_query = st_query.lower()

    if (user_query != "") and (user_query != " "):# If user query is not empty then run everything

        print('\n\n\n')
        print('-'*100)
        print('Client Scroll')
        collection_info = client.get_collection("history")
        print("Collection info:", collection_info)
        all_points, _ = client.scroll(
        collection_name="history",
        limit=1000)
        print(all_points)
        sorted_points = sorted(all_points, key=lambda p: int(p.id), reverse=True)
        last_3 = sorted_points[:2]
        history_context = "\n".join([i.payload['history'] for i in last_3])
        print('Last 3')
        print(history_context)
        print('\n\n')
        #Get relevant resumes docs
        context = get_relevant_docs(user_query=user_query,collection='resumes',filter_data=True,k= k)
        assistant_history = context.split('\n\n')[0]
        print('HISTORY')
        print(assistant_history)
        print('CONTEXT')
        print(context)
        if ("he" in user_query) or ("his" in user_query) or ("him" in user_query) or ("her" in user_query) or ("she" in user_query) or ("they" in user_query) or ("their" in user_query):
            context = ""
            history_context = "\n".join([i.payload['history'] for i in last_3[:-1]])
            assistant_history = last_3[0].payload['history']
            print('No user')

        retriever_logic = RunnableMap({
        "context": lambda x: context,
        "history": lambda x: history_context,
        "question": lambda x: x["question"]
    })
        prompt_template = PromptTemplate(
        input_variables=["context", "question","history"],
        template="""
You are a smart, friendly, and professional AI recruitment assistant helping HR teams and hiring managers identify top candidates based on internal resume data.

Candidate Context:
{context}

Conversation History:
{history}

Recruiter Question:
{question}

Response Instructions
✅ 1. Match Criteria Strictly

Only list candidates who meet all criteria stated in the recruiter question.

If the question requests a specific number of candidates (e.g., “5 resumes”), you must not generate placeholders or partial entries if fewer candidates match.

If there are fewer matching candidates than requested, only return the actual matches found and clearly state that fewer candidates were available.

✅ 2. No Inference or Partial Fulfillment

Do not invent or imply candidate details not explicitly provided in the Candidate Context.

Do not create entries labeled “No name specified” or “unknown candidate.”

Never attempt to partially fill a requested number of candidates.

✅ 3. Pronoun Resolution

If the question uses pronouns (e.g., he, she, they) without a named person:

Use the most recent relevant mention in the conversation history to resolve.

If uncertain, clearly state you cannot determine who is referenced.

✅ 4. Presentation

When presenting candidates, do not number beyond the actual matches.

Use a warm tone and an introduction such as:

“Here are the candidates who match your criteria:”

If no candidates match, respond politely:

“I reviewed the available resumes but could not find any candidates meeting all the specified criteria.”

✅ 5. Grounding and Evidence

For every candidate mentioned, reference only information explicitly contained in the Candidate Context.

Do not mention resumes, documents, or data sources.

🚫 Under No Circumstances:

Create or invent any candidates.

Use placeholders or partial entries to fill numeric requests.

Summarize or rephrase information in a way that introduces new facts.

Important Reminder:
If fewer candidates match than requested, provide only the exact number found. If none are found, state this clearly.



    """
    )

        rag_chain = retriever_logic | prompt_template | llm

        result = rag_chain.invoke({'question':user_query})
        if result:
            st.text_area("Answer",value=result.content,height = 500)
        if "retrieval_result" in st.session_state:
            selected_files = st.session_state.retrieval_result["files"]

            # Folder containing the resumes
            folder_path = "/home/anubhav/Downloads/ali_code_resume/Resume-AI_final/resumes"

            # Create an in-memory ZIP
            zip_buffer = BytesIO()

            with zipfile.ZipFile(zip_buffer, "w", zipfile.ZIP_DEFLATED) as zip_file:
                for filename in selected_files:
                    file_path = os.path.join(folder_path, filename)
                    # Double-check the file exists
                    if os.path.exists(file_path):
                        zip_file.write(file_path, arcname=filename)
                    else:
                        st.warning(f"File not found: {filename}")

            # Move buffer pointer to start
            zip_buffer.seek(0)

            # Provide download button
            # st.download_button(
            #     label="Download Selected Resumes",
            #     data=zip_buffer,
            #     file_name="resumes.zip",
            #     mime="application/zip"
            # )

        

        # Create history text from user query and rag chain result
        history = f"""User:{user_query}
    Assistant:{assistant_history}"""
        add_history(history=history)
        return zip_buffer


